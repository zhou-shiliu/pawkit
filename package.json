{
  "name": "pawkit",
  "version": "0.1.0",
  "description": "A lightweight Codex Pet-compatible desktop pet companion",
  "main": "src/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "npm run electron:dev",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "node --test scripts/test-roaming.js scripts/test-care-loop.js scripts/test-validation-metrics.js scripts/test-presence-mode.js scripts/test-visual-presence-mode.js scripts/test-pet-mvp-core.js",
    "electron:dev": "concurrently \"npm:dev:web\" \"wait-on http://localhost:5173 && PAWKIT_VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && electron-builder",
    "verify:runtime": "node scripts/verify-packaged-runtime.js",
    "verify:m1:manual": "node scripts/verify-m1-manual-qa.js",
    "verify:m2:presence": "node scripts/verify-m2-presence.js",
    "verify:m1-closure": "npm test && npm run build && npx tsc --noEmit --project tsconfig.json && npm run pack && npm run verify:runtime && npm run verify:m1:manual",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "verify:m3:livelike": "node scripts/verify-m3-lifelike-presence.js",
    "verify:pet-mvp": "node scripts/verify-pet-mvp.js",
    "dev:web": "vite --strictPort --port 5173",
    "dev:legacy": "VITE_PAWKIT_LEGACY_CARE=1 vite --strictPort --port 5173",
    "verify:pet-dialog": "node scripts/assert-pet-import-dialog.js",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never"
  },
  "keywords": [
    "desktop",
    "pet",
    "cat",
    "pixel-art",
    "companion",
    "codex-pet"
  ],
  "author": "zenus",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.10",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-store": "^8.0.0",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.zenus.pawkit",
    "productName": "Pawkit",
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "files": [
      "src/**/*",
      "dist/renderer/**/*",
      "pets/builtin/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-windows-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-windows-installer-${arch}.${ext}"
    },
    "linux": {
      "category": "Utility",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "maintainer": "Pawkit Maintainers <noreply@github.com>"
    },
    "portable": {
      "artifactName": "${productName}-${version}-windows-portable-${arch}.${ext}"
    }
  },
  "homepage": "https://github.com/zhou-shiliu/pawkit"
}
